# ---- Site ----
# Public base URL, used for Stripe redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- MongoDB ----
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/avcf

# ---- Stripe (donations) ----
STRIPE_SECRET_KEY=sk_test_...
# From `stripe listen` locally, or the dashboard webhook endpoint in production.
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- Contentful (blog) ----
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=
# Optional overrides:
# CONTENTFUL_ENVIRONMENT=master
# CONTENTFUL_BLOG_CONTENT_TYPE=blogPost

# ---- Email (Resend) ----
RESEND_API_KEY=re_...
# Verified sender. Falls back to Resend's onboarding sender if unset.
EMAIL_FROM="AVCF <hello@avcf.org>"
# Comma-separated admin recipients for contact form notifications (server-only).
CONTACT_FORM_RECIPIENTS=email1@example.com,email2@example.com
# Set to "true" to send the submitter a confirmation email.
CONTACT_SEND_CONFIRMATION=false
